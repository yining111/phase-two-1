{
    "printWidth":80,
    "tabWidth":4,
    "useTab":false,
    "semi":true,
    "singleQuote":true,
    "trailingComma":"none",
    "bracketSpacing":true,
    "jsxBracketSameLine":false,
    "arrowParens":"avoid",
    "proseWrap":"preserve",
    "htmlWhitespaceSensitivity":"css",
    "endOfLine":"auto"

}